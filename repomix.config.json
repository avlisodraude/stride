{
  "output": {
    "style": "xml",
    "filePath": "repomix-output.xml",
    "removeComments": true,
    "showLineNumbers": false
  },
  "include": ["**/*"],
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "pnpm-lock.yaml",
      "package-lock.json",
      "repomix-output.xml",
      "*.log"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}