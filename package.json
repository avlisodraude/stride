{
  "name": "@alosha/stride",
  "version": "1.0.0",
  "description": "Parse GPX, TCX and FIT files and compute running metrics — pace, HR zones, splits, and Chart.js dashboards. Zero config.",
  "keywords": [
    "gpx",
    "gpx-parser",
    "fit",
    "fit-parser",
    "fit-file",
    "tcx",
    "tcx-parser",
    "running",
    "strava",
    "garmin",
    "activity",
    "heart-rate",
    "heart-rate-zones",
    "pace",
    "splits",
    "chartjs",
    "chart",
    "activity-analysis",
    "fitness",
    "cli"
  ],
  "homepage": "https://stride.alosha.dev",
  "bugs": {
    "url": "https://github.com/avlisodraude/stride/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avlisodraude/stride.git"
  },
  "license": "MIT",
  "author": "Eduardo Silva Navarrete <avlis_odraude@hotmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./charts": {
      "import": {
        "types": "./dist/charts.d.ts",
        "default": "./dist/charts.js"
      },
      "require": {
        "types": "./dist/charts.d.cts",
        "default": "./dist/charts.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "stride": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:browser": "node scripts/build-browser.mjs",
    "dev": "tsup --watch",
    "pretest": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "sample:fit": "node scripts/make-sample-fit.mjs test/fixtures/sample-run.fit",
    "lint": "eslint src",
    "prepare": "husky",
    "release": "npm run build && npm publish --access public"
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.205.0",
    "fast-xml-parser": "^5.9.0"
  },
  "peerDependencies": {
    "chart.js": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/js": "^9.5.0",
    "@types/node": "^20.14.0",
    "chart.js": "^4.4.3",
    "eslint": "^9.5.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0"
  }
}
