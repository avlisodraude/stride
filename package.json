{
  "name": "@alosha/stride",
  "version": "0.1.4",
  "description": "Parse GPX files and compute running metrics — pace, HR zones, splits, and Chart.js dashboards. Zero config.",
  "keywords": [
    "gpx",
    "gpx-parser",
    "running",
    "strava",
    "garmin",
    "activity",
    "heart-rate",
    "heart-rate-zones",
    "pace",
    "splits",
    "chartjs",
    "chart",
    "activity-analysis",
    "fitness",
    "cli"
  ],
  "homepage": "https://stride.alosha.dev",
  "bugs": {
    "url": "https://github.com/avlisodraude/stride/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avlisodraude/stride.git"
  },
  "license": "MIT",
  "author": "Eduardo Silvanavarrete <avlis_odraude@hotmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stride": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src",
    "prepare": "husky",
    "release": "npm run build && npm publish --access public"
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "fast-xml-parser": "^4.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^20.14.0",
    "eslint": "^9.5.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
